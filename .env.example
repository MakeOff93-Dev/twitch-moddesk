APP_NAME="Twitch ModDesk"
APP_ENV=production
APP_DEBUG=false
APP_INSTALLED=false
APP_URL=http://localhost:8080
APP_KEY=change-this-to-a-long-random-secret-with-at-least-32-characters
APP_TIMEZONE=Europe/Berlin
SESSION_SECURE=false

DB_HOST=db
DB_PORT=3306
DB_DATABASE=twitch_moddesk
DB_USERNAME=twitch_moddesk
DB_PASSWORD=change-this-database-password
MYSQL_ROOT_PASSWORD=change-this-root-password

# Optionaler Fallback. Twitch kann nach der Installation im Panel konfiguriert werden.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:8080/?page=twitch-callback
